# Tushare Pro API Token
# Get yours at: https://tushare.pro/register
TUSHARE_TOKEN=your_token_here

# (Optional) Broker API URL — routes all Tushare calls through a broker endpoint
# When set, enables VIP API endpoints (income_vip, balancesheet_vip, etc.)
# TUSHARE_API_URL=http://your-broker-url.example.com
